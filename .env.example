# Odoo Connection (Required)
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database_name
ODOO_USERNAME=your_username
ODOO_PASSWORD=your_password_or_api_key

# Server Settings
TRANSPORT=stdio
PORT=3001
HOST=0.0.0.0

# Connection Pool (Optional)
ODOO_POOL_MIN=2
ODOO_POOL_MAX=10
ODOO_POOL_ACQUIRE_TIMEOUT=30000
ODOO_POOL_IDLE_TIMEOUT=300000
ODOO_POOL_EVICTION_INTERVAL=60000
ODOO_POOL_TEST_ON_BORROW=true
