{
  "name": "odoo-manufacturing-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for analyzing Odoo Manufacturing Order costs with BOM explosion and variance analysis",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');if(!fs.existsSync('dist/knowledge'))fs.mkdirSync('dist/knowledge',{recursive:true})\"",
    "build": "tsc && npm run copy-json",
    "copy-json": "node -e \"const fs=require('fs');const p=require('path');const src='src/knowledge';const dst='dist/knowledge';if(fs.existsSync(src)){fs.readdirSync(src).filter(f=>f.endsWith('.json')).forEach(f=>fs.copyFileSync(p.join(src,f),p.join(dst,f)))}\"",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "generic-pool": "^3.9.0",
    "lru-cache": "^11.2.4",
    "xmlrpc": "^1.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/xmlrpc": "^1.3.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
